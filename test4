import sys

def get_prime_factors(n):
    factors = []
    # Handle 2s
    while n % 2 == 0:
        factors.append(2)
        n //= 2
    
    # Handle odd numbers
    for i in range(3, int(n**0.5) + 1, 2):
        while n % i == 0:
            factors.append(i)
            n //= i
            
    # If n is still > 2, it's prime
    if n > 2:
        factors.append(n)
    return factors

def main():
    try:
        # Read input from stdin
        line = sys.stdin.read().strip()
        if not line:
            return
        
        n = int(line)
        
        if n <= 1:
            print("Invalid")
            return
            
        factors = get_prime_factors(n)
        
        # Print factors separated by space
        print(" ".join(map(str, factors)))
        
        # Print the sum of factors
        print(sum(factors))
        
    except ValueError:
        print("Invalid")

if __name__ == "__main__":
    main()
